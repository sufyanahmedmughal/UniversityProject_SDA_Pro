{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,

    "incremental": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "strict": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../event-bus/src/**/*.ts", "../shared/**/*.ts"]
}